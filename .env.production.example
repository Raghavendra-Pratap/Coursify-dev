# Copy to .env.production on your VPS (never commit the real file)
# cp .env.production.example .env.production

# --- Build-time (also used by docker compose build args) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
NEXT_PUBLIC_APP_URL=https://coursify.yourdomain.com

# Optional public
# NEXT_PUBLIC_ASSESSMENT_PRO_ORIGIN=https://assessments.bsoc.space

# --- Runtime (server-only; not baked into the client bundle) ---
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Email (Resend)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Coursify <notifications@yourdomain.com>

# Optional integrations
# ASSESSMENT_PRO_BASE_URL=
# ASSESSMENT_PRO_COMPANY_SLUG=
# ASSESSMENT_PRO_API_KEY=
# ASSESSMENT_PRO_WEBHOOK_SECRET=
# MAGIC_LINK_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://coursify.yourdomain.com/auth/drive-callback

# Host port mapping for docker compose (default 3000)
# APP_PORT=3000
