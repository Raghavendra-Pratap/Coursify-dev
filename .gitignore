# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (ignore all node_modules, including in subprojects e.g. coursify-app/)
node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js (root and subprojects)
.next/
out/

# production
/build

# misc
.DS_Store
*.pem

# project scripts and config (port, etc.)
scripts/
config/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# cursor rules
*.cursorrules

# --- Optional (uncomment if you want) ---
.cursor/                    # Cursor IDE config (some teams commit this for shared rules)
sample ui/                  # Reference UI only; exclude from repo to keep repo smaller
coursify-app/.env.local     # Already covered by .env*.local; add if nested env not ignored
*.log                       # All log files (npm-debug already above)
.env.production
docker/vendor
