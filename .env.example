# Coursify LMS – environment variables
# Copy to .env.local for local dev:  cp .env.example .env.local
# For production (Vercel etc.): set these in your host's dashboard (see DEPLOYMENT.md)
#
# Required for auth, DB, and learning progress (My learning page, progress API):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for server-side APIs (progress recalc, enrolled list, course content, structure, etc.)
# Get from Supabase: Project Settings → API → service_role key. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# Optional – app URL (used in magic links, share links, emails). Set to your public domain so the Vercel URL is hidden.
# Production example: https://coursify.bsoc.space
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional – Google Drive OAuth (redirect URI must match your app URL)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/drive-callback

# Optional – Resend (sending invite and reminder emails)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Coursify <onboarding@resend.dev>

# Optional – Google Form quiz webhook (signed one-time tokens for recording scores)
# Must be at least 32 characters. Used to sign/verify quiz-submit tokens; leave unset to disable webhook scoring.
# WEBHOOK_QUIZ_SECRET=

# Optional – Course magic links (share /go/TOKEN instead of /course/UUID). Min 16 characters.
# If unset, Share modal falls back to the direct course URL.
# MAGIC_LINK_SECRET=

# Assessment Pro (production: set on Vercel for coursify.bsoc.space)
# ASSESSMENT_PRO_BASE_URL=https://assessments.bsoc.space
# ASSESSMENT_PRO_COMPANY_SLUG=coursify-bsoc-space
# ASSESSMENT_PRO_API_KEY=              # same as AP COURSIFY_INTEGRATION_API_KEY
# ASSESSMENT_PRO_WEBHOOK_SECRET=       # same as AP COURSIFY_WEBHOOK_SECRET
# NEXT_PUBLIC_ASSESSMENT_PRO_ORIGIN=https://assessments.bsoc.space

# Optional – Dev-only demo user (for scripts/create-demo-user.mjs). Use only with a dev Supabase project.
# DEMO_USER_EMAIL=demo@example.com
# DEMO_USER_PASSWORD=DemoDev123!
