# Coursify LMS – environment variables
# Copy to .env.local for local dev:  cp .env.example .env.local
# For production (Vercel etc.): set these in your host's dashboard (see DEPLOYMENT.md)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional – server-side only (e.g. delete-account API). Never expose to client.
# SUPABASE_SERVICE_ROLE_KEY=

# Optional – Google Drive OAuth (redirect URI must match your app URL)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/drive-callback
