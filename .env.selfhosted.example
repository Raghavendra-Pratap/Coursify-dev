# Self-hosted Supabase + Coursify (local or VPS)
# Copy: cp .env.selfhosted.example .env.production
# Keys: run ./docker/print-keys.sh after ./docker/setup-supabase.sh
#
# Never commit .env.production

# --- Public API (Kong). Browser and server both use this URL. ---
# Local:  http://localhost:8000
# VPS:    https://api.yourdomain.com
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000

# From Supabase docker .env (ANON_KEY) — ./docker/print-keys.sh
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App URL (OAuth redirects, invite links)
# VPS: https://coursify.yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Optional
# NEXT_PUBLIC_ASSESSMENT_PRO_ORIGIN=https://assessments.bsoc.space

# --- Server-only (mark Sensitive on VPS secrets store) ---
SUPABASE_SERVICE_ROLE_KEY=

# RESEND_API_KEY=
# RESEND_FROM_EMAIL="Coursify <notifications@yourdomain.com>"

# Google OAuth — also configure via ./docker/configure-google-oauth.sh
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# YouTube Data API v3 — server-only; Import from YouTube in Create Course
# Enable "YouTube Data API v3" in Google Cloud Console → Credentials → API key
# YOUTUBE_API_KEY=

# ASSESSMENT_PRO_* , MAGIC_LINK_SECRET — same as cloud deploy

# docker compose host port (default 3001 local so Supabase Studio can use 3000)
APP_PORT=3001
